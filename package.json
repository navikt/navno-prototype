{
  "name": "navno-prototype",
  "version": "0.1.0",
  "description": "",
  "author": "Martin Berglund <marberglund@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/macbruker/navno-prototype"
  },
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "eleventy-debug": "DEBUG=Eleventy* pnpm exec eleventy",
    "dev:eleventy": "pnpm exec eleventy --config=eleventy.config.mjs --serve",
    "dev:css": "pnpm exec tailwindcss -i ./src/assets/main.css -o ./build/assets/main.min.css --watch",
    "dev": "ELEVENTY_ENV=development pnpm run \"/^dev:.*/\"",
    "build:eleventy": "ELEVENTY_ENV=production pnpm --config=eleventy.config.mjs",
    "build:css": "NODE_ENV=production pnpm exec tailwindcss -i ./src/assets/main.css -o ./build/assets/main.min.css",
    "build": "pnpm run \"/^build:.*/\"",
    "serve": "NODE_ENV=production ELEVENTY_ENV=production pnpm exec eleventy --config=eleventy.config.mjs --serve",
    "start": "node ./server/app.js"
  },
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@alpinejs/intersect": "^3.15.8",
    "@sindresorhus/slugify": "^3.0.0",
    "@tailwindcss/cli": "^4.1.18",
    "alpinejs": "^3.15.8",
    "autoprefixer": "^10.4.24",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.4",
    "eleventy-plugin-svg-contents": "^0.7.0",
    "eleventy-plugin-toc": "^1.1.5",
    "html-minifier-terser": "^7.2.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-toc-done-right": "^4.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-multiline-arrays": "^4.1.4",
    "tailwindcss": "^4.1.18"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "path": "^0.12.7",
    "pnpm": "^10.29.3",
    "test": "^3.3.0"
  }
}