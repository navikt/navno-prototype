<!DOCTYPE html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>
      {{- title | safe }}
      {{- ' &ndash; ' | safe if title }}
      {{- site.title | safe }}
    </title>
    <meta name="description" content="..." />

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2299%22>🧑‍💻</text></svg>" />
    <link rel="preconnect" href="{{ 'https://navikt.github.io/navno-prototype' if environment == 'production' else 'http://localhost/' }}" crossorigin />
    <link rel="preload" href="/assets/fonts/SourceSans3-normal-latin.woff2" as="font" type="font/woff2" crossorigin>
    <style>
      @font-face {
        font-family: "Source Sans 3";
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
        src: url("{{ '/assets/fonts/SourceSans3-normal-latin.woff2' | htmlBaseUrl }}") format("woff2");
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA,
          U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212,
          U+2215, U+FEFF, U+FFFD;
      }

      @font-face {
        font-family: "Source Sans 3";
        font-weight: 100 900;
        font-style: italic;
        font-display: swap;
        src: url("{{ '/assets/fonts/SourceSans3-italic-latin.woff2' | htmlBaseUrl }}") format("woff2");
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA,
          U+02DC, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212,
          U+2215, U+FEFF, U+FFFD;
      }
    </style>
    {% css %}{% include "../assets/main.css" %}{% endcss %}
    {% if environment == 'production' %}
    <link rel="stylesheet" href="{% getBundleFileUrl 'css' %}" type="text/css" />
    {% else %}
    <style>{% getBundle "css" %}</style>
    {% endif %}
  </head>
  <body style="{{ '--_body:#fbf3f6' if account.type == 'agent' }}">
    {%- if page.url != '/idporten/' %}     
    {% include "partials/header.njk" %}
    {%- endif %}
    <main class="site-content">
      {{- content | safe -}}
    </main>
    <footer class="site-footer">

    </footer>
    <!-- Generated: '{{ generated | capitalize | safe }}' -->
  </body>
</html>
