{% macro search(class, id) %}
  <form class="{{ class }}" action="#" style="view-transition-name: search">
    <label for="{{ id }}">
      <svg width="20" height="20" fill="none" viewBox="0 0 20 20">
        <circle cx="8.33" cy="8.33" r="5.83" stroke="currentColor" stroke-width="1.5"/>
        <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="m12.92 12.92 4.16 4.16"/>
      </svg>
      <span class="sr-only">Søk</span>        
    </label>
    <input id="{{ id }}" placeholder="Søk på nav.no" type="search">
  </form>
{% endmacro %}


<header class="site-header container">
  <div class="site-navigation">

    <a class="site-logo" href="/">
      {{ "/src/assets/images/logo.svg" | svgContents | safe }}
      <span class="sr-only">Nav</span>
    </a>

    <div class="site-audience">
      <button popovertarget="audience">
        <span>{{ site.audience[0] }}</span>
        {{ '/src/assets/images/icon-chevrondown.svg' | svgContents | safe }}
      </button>
      <div id="audience" popover>
        {%- for audience in site.audience %}
        <a href="#" {{- 'aria-current=page' if loop.first -}}>{{ audience }}</a>
        {%- endfor %}
      </div>
    </div>

    {{ search('site-search site-search--large', 'site-search-1') }}

    <nav class="site-menu">
      <button popovertarget="site-menu" style="view-transition-name: hamburger">
        <span>Meny</span>

        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" eleventy:ignore>
          <defs>
            <clipPath id="spyglassMask">
              <path class="hamburger-spyglass" fill="black" d="m5.5 0 2.65 4.24a8.5 8.5 0 0 0 7.96 12.74L20.5 24H-15V0z"/>
            </clipPath>
          </defs>
          <g stroke="currentColor" stroke-linecap="round" stroke-width="1.8" clip-path="url(#spyglassMask)">
            <path d="M3 5h18M3 12h18M3 19h18"/>
          </g>
          <g class="hamburger-spyglass">
          <circle cx="15" cy="8.5" r="5" stroke="currentColor" stroke-width="1.8" transform="rotate(90 15 8.5)"/>
          <path stroke="currentColor" stroke-linecap="round" stroke-width="1.8" d="m17.5 13 3.5 6"/>
          </g>
        </svg>
      </button>
      <div id="site-menu" popover>
        <div class="container">
          <div class="site-menu-content">
            {{ search('site-search site-search--small', 'site-search-2') }}

            <div>
              <h2>{{ menu.areas.title }}</h2>
              <ul class="menu-tiles">
                {% for item in menu.areas.linkList %}
                <li>
                  <a href="{{ item.href or '#' }}">
                    {% if item.icon %}
                      {{- item.icon | svgContents | safe -}}
                    {% endif %}
                    <span>{{ item.text }}</span>
                  </a>
                </li>
                {% endfor %}
              </ul>
            </div>
            <div class="menu-col-separator"></div>

            <div>
              <h2>{{ menu.shortcuts.title }}</h2>
              <ul class="menu-list">
                {% for item in menu.shortcuts.linkList %}
                <li>
                  <a href="{{ item.href or '#' }}">
                    {% if item.icon %}
                      {{- item.icon | svgContents | safe -}}
                    {% endif %}
                    <span>{{ item.text }}</span>
                  </a>
                </li>
                {% endfor %}
              </ul>
            </div>

          </div>
        </div>
      </div>
    </nav>
  </div>



  <div class="site-account">
    {%- if loggedIn %}
    <button class="site-account-button agent" popovertarget="site-account-menu" type="button">
      <div class="agent__text stack-text">
        <strong>{{ site.agents[0].name }}</strong>
        {#- <small>{{ site.notifications | length }} oppgaver venter</small> #}
        <small>{%- if not agent.name or agent.type == 'main' -%}
          {{ site.agents[0].role }}
          {%- else %}
          På vegne av {{ agent.name }}
          {%- endif %}</small>
      </div>
      <div class="agent__icon avatar {{ 'avatar--main' if agent.type != 'agent' }}" style="view-transition-name: avatar-{{ agent.name | slugify }}">
        {{ (agent.icon or site.agents[0].icon) | svgContents | safe }}
      </div>
    </button>
    <div class="site-account-menu" id="site-account-menu" popover>
      <div>
        <a href="/{{ (agent.name or site.agents[0].name) | slugify }}/minside/">
          {{ '/src/assets/images/icon-squaregrid.svg' | svgContents | safe }}
          <div class="stack-text">
            <strong>
              Min side ({{ agent.name }})
              </strong>
            <small>2 oppgaver venter</small>
          </div>
        </a>
        <a href="#">
          {{ '/src/assets/images/icon-informationsquare.svg' | svgContents | safe }}
          <div class="stack-text">
            <strong>Personopplysninger</strong>
            <small>Kontaktinfo, kontonummer, osv.</small>
          </div>
        </a>
        <a href="/{{ agent.name | slugify }}/representasjon/">
          {{ '/src/assets/images/icon-persongroup.svg' | svgContents | safe }}
          <div class="stack-text">
            <strong>Representasjon</strong>
            <small>Personer du kan representere</small>
          </div>
        </a>
        <div class="agent-switcher scroll-container">
          <p class="stack-text">
            <strong>Velg profil</strong>
          </p>
          {% for i in range(0,1) %}
          {% for profile in site.agents %}
            <a class="agent" href="/{{ profile.name | slugify }}/minside/">
              <div class="agent__icon avatar {{ 'avatar--main' if profile.type != 'agent' }}" style="view-transition-name: avatar-{{ profile.name | slugify }}">
                {{ profile.icon | svgContents | safe }}
              </div>
              <div class="agent__text stack-text">
                <strong>{{ profile.name }}</strong>
                <small>{{ profile.role }}</small>
              </div>
            </a>
          {% endfor %}
          {% endfor %}
        </div>
      </div>
      <div>
        <a href="/">
          {{ '/src/assets/images/icon-leave.svg' | svgContents | safe }}
          <strong style="line-height:1.8">Logg ut</strong>
        </a>
      </div>
    </div>
    {%- else %}
    <a class="site-account-button" href="/idporten/">Logg inn</a>
    {%- endif %}
  </div>

  {#- {% if agent.type === 'agent' %}
  <div class="site-agency">
    <p>Du bruker denne siden på vegne av <strong>{{ agent.name }}</strong>. <a href="/representasjon/">Bytt profil</a></p>
  </div>
  {%- endif %} #}
</header>


