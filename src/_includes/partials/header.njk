{% macro search(class, searchId, suggestId) %}
<div class="{{ class }}">
  <form action="#" style="view-transition-name: search">
    <label for="{{ searchId }}">
      <svg width="20" height="20" fill="none" viewBox="0 0 20 20">
        <circle cx="8.33" cy="8.33" r="5.83" stroke="currentColor" stroke-width="1.5"/>
        <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="m12.92 12.92 4.16 4.16"/>
      </svg>
      <span class="sr-only">Søk</span>
    </label>
    <input id="{{ searchId }}" placeholder="Søk på nav.no" popovertarget="{{ suggestId }}" type="search">
  </form>
  <div class="site-search-suggestion" id="{{ suggestId }}" popover>
   <div class="container  container--prose">[ Søkeforslag ]</div>
  </div>
  <script>
    const {{ searchId }} = document.getElementById('{{ searchId}}');
    const {{ suggestId }} = document.getElementById('{{ suggestId }}')

    {{ searchId }}.addEventListener("click", () => {
      {{ suggestId }}.togglePopover()
    })
  </script>
</div>
{% endmacro %}


<header class="site-header container">
  <div class="site-navigation">

    <a class="site-logo" href="/{{ (user.name or users[0].name) | slugify }}/">
      {{ "/src/assets/images/logo.svg" | svgContents | safe }}
      <span class="sr-only">Nav</span>
    </a>

    <div class="site-audience">
      <button popovertarget="audienceChooser">
        <span>{{ role.title or roles[0].title }}</span>
        {{ '/src/assets/images/icon-chevrondown.svg' | svgContents | safe }}
      </button>
      <div id="audienceChooser" popover>
        {%- for role in roles %}
        <a href="{{ ('/' + (user.name | slugify) + '/') if user.name or '' }}{{ role.url }}" {{- 'aria-current=page' if loop.first -}}>{{ role.title }}</a>
        {%- endfor %}
      </div>
    </div>

    {{ search('site-search site-search--large', 'siteSearch1', 'siteSearchSuggestions1') }}

    <nav class="site-menu">
      <button popovertarget="site-menu" style="view-transition-name: hamburger">
        <span>Meny</span>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" eleventy:ignore>
          <defs>
            <clipPath id="spyglassMask">
              <path class="hamburger-spyglass" fill="black" d="m5.5 0 2.65 4.24a8.5 8.5 0 0 0 7.96 12.74L20.5 24H-15V0z"/>
            </clipPath>
          </defs>
          <g stroke="currentColor" stroke-linecap="round" stroke-width="1.8" clip-path="url(#spyglassMask)">
            <path d="M3 5h18M3 12h18M3 19h18"/>
          </g>
          <g class="hamburger-spyglass">
          <circle cx="15" cy="8.5" r="5" stroke="currentColor" stroke-width="1.8" transform="rotate(90 15 8.5)"/>
          <path stroke="currentColor" stroke-linecap="round" stroke-width="1.8" d="m17.5 13 3.5 6"/>
          </g>
        </svg>
      </button>
      <div id="site-menu" popover>
        <div class="container">
          <div class="site-menu-content">

            {{ search('site-search site-search--small', 'siteSearch2', 'siteSearchSuggestions2') }}

            <div>
              <h2>{{ menu.areas.title }}</h2>
              <ul class="menu-tiles">
                {% for item in menu.areas.linkList %}
                <li>
                  <a href="{{ item.href or '#' }}">
                    {% if item.icon %}
                      {{- item.icon | svgContents | safe -}}
                    {% endif %}
                    <span>{{ item.text }}</span>
                  </a>
                </li>
                {% endfor %}
              </ul>
            </div>

            <div class="menu-col-separator"></div>

            <div>
              <h2>{{ menu.shortcuts.title }}</h2>
              <ul class="menu-list">
                {% for item in menu.shortcuts.linkList %}
                <li>
                  <a href="{{ item.href or '#' }}">
                    {% if item.icon %}
                      {{- item.icon | svgContents | safe -}}
                    {% endif %}
                    <span>{{ item.text }}</span>
                  </a>
                </li>
                {% endfor %}
              </ul>
            </div>

            <div class="menu-footer">
              <p>Bytt til <a href="{{ ('/' + (user.name | slugify) + '/arbeidsgiver/') if user.name else '/arbeidsgiver/' }}">arbeidsgiver</a> eller <a href="{{ ('/' + (user.name | slugify) + '/samarbeidspartner/') if user.name else '/samarbeidspartner/' }}">samarbeidspartner</a>.</p>
            </div>

          </div>
        </div>
      </div>
    </nav>
  </div>

  <div class="site-account">
    {%- if user.name %}
    <button class="site-account-button account" popovertarget="site-account-menu" type="button">
      <div class="account__text stack-text">
        <strong>{{ user.name if user.type == 'agent' else users[0].name }}</strong>
        <small>
          {{ (user.tasks or users[0].tasks) | length }} ny{{ 'e' if user.tasks.length != 1 }} oppgave{{ 'r' if user.tasks.length != 1 }}
        </small>
      </div>
      <div class="account__icon">
        <div class="avatar {{ 'avatar--self' if user.type != 'agent' }}" style="view-transition-name: avatar-{{ user.name | slugify }}">
        {{ (user.icon or users[0].icon) | svgContents | safe }}
        </div>
        {% if (user.tasks | length) >= 1 %}
          <span class="account__tasks">{{ user.tasks | length }}</span>
        {% endif %}
        <div></div>
      </div>
    </button>
    <div class="site-account-menu" id="site-account-menu" popover>
      <div>
        <a href="/{{ (user.name or users[0].name) | slugify }}/minside/">
          {{ '/src/assets/images/icon-squaregrid.svg' | svgContents | safe }}
          <div class="stack-text">
            <strong>
              Min side ({{ user.name }})
              </strong>
            <small>2 oppgaver venter</small>
          </div>
        </a>
        <a href="/{{ user.name | slugify }}/personopplysninger/">
          {{ '/src/assets/images/icon-informationsquare.svg' | svgContents | safe }}
          <div class="stack-text">
            <strong>Personopplysninger</strong>
            <small>Kontaktinfo, kontonummer, osv.</small>
          </div>
        </a>
        <a href="/{{ user.name | slugify }}/representasjon/">
          {{ '/src/assets/images/icon-personrectangle.svg' | svgContents | safe }}
          <div class="stack-text">  
            <strong>Representasjon</strong>
            <small>Oversikt over tilganger</small>
          </div>
        </a>
        {% if user.type == 'self' %}
        <a href="/{{ users[0].name | slugify }}/bytt-bruker/">
          {{ '/src/assets/images/icon-persongroup.svg' | svgContents | safe }}
          <div class="stack-text">
            <strong>Bytt bruker</strong>
            <small>Personer du kan representere</small>
          </div>
        </a>
        {% else %}
        {% set oldName = (user.name | slugify) %}
        {% set newName = (users[0].name | slugify) %}
        <a href="{{ page.url | replace(oldName, newName) }}">
          {{ '/src/assets/images/icon-personminus.svg' | svgContents | safe }}
          <div class="stack-text">
            <strong>Avslutt representasjon</strong>
            <small>Bytter til {{ users[0].name }}</small>
          </div>
        </a>
        {% endif %}
        <a href="/">
          {{ '/src/assets/images/icon-leave.svg' | svgContents | safe }}
          <strong style="line-height:1.8">Logg ut</strong>
        </a>
      </div>
    </div>
    {%- else %}
    <a class="site-account-login" href="/idporten/">
      <span>Logg inn</span>
      {{ '/src/assets/images/icon-padlocklocked.svg' | svgContents | safe }}
    </a>
    {%- endif %}
  </div>
  {% if (user.type == 'agent') and (page.url != '/') %}
  <div class="site-agentmode">
    Representeres av {{ users[0].name }}
    {# &nbsp; | &nbsp; <a href="/charlie-jensen/minside/">Avslutt representasjon</button> #}
  </div>
  {% endif %}
</header>
