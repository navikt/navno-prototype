{% macro search(class, id) %}
  <form class="{{ class }}" action="#" style="view-transition-name: search">
    <label for="{{ id }}">
      <svg width="20" height="20" fill="none" viewBox="0 0 20 20">
        <circle cx="8.33" cy="8.33" r="5.83" stroke="currentColor" stroke-width="1.5"/>
        <path stroke="currentColor" stroke-linecap="round" stroke-width="1.5" d="m12.92 12.92 4.16 4.16"/>
      </svg>
      <span class="sr-only">Søk</span>        
    </label>
    <input id="{{ id }}" placeholder="Søk på nav.no" type="search">
  </form>
{% endmacro %}


<header class="site-header container">
  <div class="site-navigation">

    <a class="site-logo" href="/">
      {{ "/src/assets/images/logo.svg" | svgContents | safe }}
      <span class="sr-only">Nav</span>
    </a>

    <div class="site-audience">
      <button popovertarget="audience">
        <span>{{ site.audience[0] }}</span>
        {{ '/src/assets/images/icon-chevrondown.svg' | svgContents | safe }}
      </button>
      <div id="audience" popover>
        {%- for audience in site.audience %}
        <a href="#" {{- 'aria-current=page' if loop.first -}}>{{ audience }}</a>
        {%- endfor %}
      </div>
    </div>

    {{ search('site-search site-search--large', 'site-search-1') }}

    <nav class="site-menu">
      <button popovertarget="site-menu" style="view-transition-name: hamburger">
        <span>Meny</span>

        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <style>
            :is(#spyglassClip,#spyglassGroup) {
              transition: translate 200ms ease-in-out;
              @media (width > 840px) { translate:15px }
            }
          </style>
          <defs>
            <clipPath id="a">
              <path id="spyglassClip" fill="black" d="m5.5 0 2.65 4.24a8.5 8.5 0 0 0 7.96 12.74L20.5 24H-15V0z"/>
            </clipPath>
          </defs>
          <g stroke="currentColor" stroke-linecap="round" stroke-width="1.8" clip-path="url(#a)">
            <path d="M3 5h18M3 12h18M3 19h18"/>
          </g>
          <g id="spyglassGroup">
          <circle cx="15" cy="8.5" r="5" stroke="currentColor" stroke-width="1.8" transform="rotate(90 15 8.5)"/>
          <path stroke="currentColor" stroke-linecap="round" stroke-width="1.8" d="m17.5 13 3.5 6"/>
          </g>
        </svg>
      </button>
      <div id="site-menu" popover>
        <div class="container">
          <div class="site-menu-content">
            {{ search('site-search site-search--small', 'site-search-2') }}

            {% for section in menu %}
              <div>
                <h2>{{ section.title }}</h2>
                <ul>
                  {% for item in section.linkList %}
                  <li>
                    <a href="{{ item.href or '#' }}">
                      {% if item.icon %}
                        {{- item.icon | svgContents | safe -}}
                      {% endif %}
                      <span>{{ item.text }}</span>
                    </a>
                  </li>
                  {% endfor %}
                </ul>
              </div>
              {% if loop.first %}
                <div class="menu-col-separator"></div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </nav>
  </div>



  <div class="site-account">
    {%- if loggedIn %}
    <button class="site-account-button agent" popovertarget="site-account-menu" type="button">
      <div class="agent__text stack-text">
        <strong>{{ site.accounts[0].name }}</strong>
        {#- <small>{{ site.notifications | length }} oppgaver venter</small> #}
        <small>{%- if not account.name or account.type == 'main' -%}
          {{ site.accounts[0].role }}
          {%- else %}
          På vegne av {{ account.name }}
          {%- endif %}</small>
      </div>
      <div class="agent__icon avatar {{ 'avatar--main' if account.type != 'agent' }}">
        {{ (account.icon or site.accounts[0].icon) | svgContents | safe }}
      </div>
    </button>
    <div class="site-account-menu" id="site-account-menu" popover>
      <div>
        <a class="stack-text" href="/{{ (account.name or site.accounts[0].name) | slugify }}/minside/">
          <strong>Min side</strong>
          <small>2 oppgaver venter</small>
        </a>
        <div class="site-agency-switcher">
          <a class="stack-text" href="/{{ account.name | slugify }}/representasjon/">
            <strong>Velg profil</strong>
            <small>Personer du kan representere</small>
          </a>
          <details>
            <summary>
              <span class="sr-only">Hurtigbytte</span>
              {{ '/src/assets/images/icon-chevrondown.svg' | svgContents | safe }}
            </summary>
            <div>
              {% for item in site.accounts %}
                <a class="agent" href="/{{ item.name | slugify }}/minside/">
                  <div class="agent__icon avatar {{ 'avatar--main' if item.type != 'agent' }}">
                    {{ item.icon | svgContents | safe }}
                  </div>
                  <div class="agent__text stack-text">
                    <strong>{{ item.name }}</strong>
                    <small>{{ item.role }}</small>
                  </div>
                </a>
              {% endfor %}
            </div>
          </details>
        </div>
        <a href="#" class="stack-text">
          <strong>Personopplysninger</strong>
          <small>Kontaktinfo, kontonummer, osv.</small>
        </a>
      </div>
      <div class="separator-line"></div>
      <div>
        <a href="/"><strong style="line-height:1.8">Logg ut</strong></a>
      </div>
    </div>
    {%- else %}
    <a class="site-account-button" href="/idporten/">Logg inn</a>
    {%- endif %}
  </div>

  {#- {% if account.type === 'agent' %}
  <div class="site-agency">
    <p>Du bruker denne siden på vegne av <strong>{{ account.name }}</strong>. <a href="/representasjon/">Bytt profil</a></p>
  </div>
  {%- endif %} #}
</header>


