---
layout: "base.njk"
title: "Bytt bruker"
loggedIn: true
user:
  name: Charlie Jensen
permalink: "/{{ users[0].name | slugify }}/bytt-bruker/index.html"
---
<div class="container container--prose account-selection">
  <div class="page-crumbs"><a href="/{{ users[0].name | slugify }}/minside/">Min side</a> /</div>
  <h1>{{ title }}</h1>
  <p></p>

  {%- for user in users.slice(0,1) %}
  <div class="account-option card card--ghost">
    <div class="avatar {{ 'avatar--self' if user.type != 'agent' }}">
      {{ user.icon | svgContents | safe }}
    </div>
    <div class="stack-text">
      <strong>{{ user.name }}</strong>
      <small>{{ user.role }}</small>
    </div>
    <span class="tag">Deg</span>
  </div>
  {%- endfor %}


  <div style="margin-block:1lh;">
    {%- for user in users.slice(1, 9) %}
    <a href="/{{ user.name | slugify }}/minside/" class="account-option card">
      <div class="avatar {{ 'avatar--self' if user.type != 'agent' }}">
        {{ user.icon | svgContents | safe }}
      </div>
      <div class="stack-text">
        <strong>{{ user.name }}</strong>
        <small>{{ user.role }}</small>
      </div>
    </a>
    {%- endfor %}
  </div>

  <p><a href="/{{ user.name | slugify }}/representasjon/">Mer om representasjon og fullmakter</a></p>

</div>
