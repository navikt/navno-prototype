---
layout: "base.njk"
loggedIn: true
pagination:
  data: users
  size: 1
  alias: user
permalink: "/{{ user.name | slugify }}/minside/index.html"
---

<div class="container container--prose">
  <header class="page-header">
    <div class="page-crumbs"><span>Min side</span></div>
    <h1>Hei, {{ user.name or users[0].name }}</h1>
  </header>

  <div class="page-section card">
    <a href="/{{ user.name | slugify }}/minside/dialog/" class="stack-text">
      <strong>Dialog med Nav</strong>
      <small>Ingen nye meldinger</small>
    </a>
  </div>

  <section class="page-section">
    <h2 class="page-section__title">Oppgaver</h2>

    <div class="page-section__content" style="display:grid; gap:var(--ax-space-6)">
      {%- if (user.tasks | length) > 0 %}
        {%- for task in user.tasks %}
        <div class="card">
          <h3><a href="#">{{ task.title }}</a></h3>
          <p><small>{{ task.description }}</small></p>
        </div>
        {%- endfor %}
      {% else %}
        Ingen nye oppgaver venter
      {%- endif %}

      <a href="#">Tidligere oppgaver</a>
    </div>
  </section>

  {% if user.products %}
  <section class="page-section">
    <h2 class="page-section__title">Pengestøtte</h2>
    <div class="page-section__content" style="display:grid; gap:var(--ax-space-6)">
      {%- for product in user.products %}
      <article class="card card--product stack-text" {{- 'data-status=new' if loop.first -}}>
        <a class="card__title" href="/{{ user.name | slugify }}/minside/{{ product.title | slugify }}/">{{ product.title }}</a>
        <small>{{ product.status }}</small>
      </article>
      {%- endfor %}
    </div>
  </section>
  {% endif %}

</div>
